{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "src": "/pfp", "dest": "/api/pfp.py" },
    { "src": "/", "dest": "/api/index.py" },
    { "src": "/static/(.*)", "dest": "/public/$1" }
  ]
}
